# systemd-sysupdate transfer for the tools sysext.
# Install on the host as /etc/sysupdate.tools.d/tools.transfer and update with
# `systemd-sysupdate -C tools update`.
[Transfer]
Verify=false

[Source]
Type=url-file
Path=https://github.com/tesserac-ai/flatcar-packages/releases/download/tools/
MatchPattern=tools-@v-%a.raw

[Target]
InstancesMax=3
Type=regular-file
Path=/opt/extensions/tools
MatchPattern=tools-@v-%a.raw
CurrentSymlink=/etc/extensions/tools.raw
